/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

// Test-specific parameters and resource limits.
params {
    modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/atacportray'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners

// Cap resources for local (sandbox) stub testing
process {
    resourceLimits = [ cpus: 4, memory: '12.GB', time: '1.h' ]
}
