/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.

    All ext.args below reproduce the EXACT parameters of the atacportray reference
    notebook (Toumi et al., NAR Genomics and Bioinformatics 2026).
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // =========================================================================
    //  Read trimming
    // =========================================================================
    withName: 'FASTP' {
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/fastp/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{json,html,log}"
        ]
    }

    // =========================================================================
    //  EPIGENOME branch (exact notebook parameters)
    // =========================================================================
    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:BOWTIE2_ALIGN' {
        // Notebook: bowtie2 -N 0 --very-sensitive-local
        ext.args   = '-N 0 --very-sensitive-local'
        ext.prefix = { "${meta.id}.bowtie2" }
        publishDir = [
            path: { "${params.outdir}/epigenome/bowtie2/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bam,log}"
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:SAMTOOLS_VIEW' {
        // Notebook: samtools view -F 4 (keep mapped reads), output BAM
        ext.args   = '-b -F 4'
        ext.prefix = { "${meta.id}.mapped" }
        publishDir = [ enabled: false ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:BEDTOOLS_INTERSECT' {
        // Notebook: bedtools intersect -v against ENCODE blacklist
        ext.args   = '-v'
        ext.prefix = { "${meta.id}.noblacklist" }
        ext.suffix = 'bam'
        publishDir = [ enabled: false ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.filtered.sorted" }
        publishDir = [
            path: { "${params.outdir}/epigenome/bam/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.bam"
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:SAMTOOLS_STATS' {
        ext.prefix = { "${meta.id}.filtered.sorted" }
        publishDir = [
            path: { "${params.outdir}/epigenome/samtools/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.stats"
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:DEEPTOOLS_BAMCOVERAGE' {
        // Notebook: bamCoverage -bs 20 --smoothLength 100 --extendReads
        ext.args   = {
            [
                "--binSize ${params.bamcoverage_binsize}",
                "--smoothLength ${params.bamcoverage_smoothlength}",
                "--extendReads",
                "--normalizeUsing ${params.bamcoverage_normalization}"
            ].join(' ')
        }
        ext.prefix = { "${meta.id}.coverage" }
        publishDir = [
            path: { "${params.outdir}/epigenome/bigwig/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.bigWig"
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:MACS3_CALLPEAK' {
        // Notebook: macs3 callpeak --format BAMPE --gsize hs --keep-dup all --qvalue 0.1
        ext.args   = {
            [
                "--format ${params.macs_format}",
                "--keep-dup ${params.macs_keepdup}",
                "--qvalue ${params.macs_qvalue}",
                "--nomodel"
            ].join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/epigenome/peaks/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{narrowPeak,broadPeak,xls}"
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:CONSENSUS_PEAKS' {
        publishDir = [
            path: { "${params.outdir}/epigenome/consensus_peaks" },
            mode: params.publish_dir_mode
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:ROSE' {
        // Notebook: ROSE -g HG38 -s 12500 -t 2500
        publishDir = [
            path: { "${params.outdir}/epigenome/rose/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:NUCLEOATAC' {
        // NucleoATAC run: occ -> vprocess -> nuc -> merge -> nfr over MACS3 peaks
        publishDir = [
            path: { "${params.outdir}/epigenome/nucleoatac/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:TOBIAS_ATACORRECT' {
        publishDir = [
            path: { "${params.outdir}/epigenome/tobias/atacorrect/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }
    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:TOBIAS_SCOREBIGWIG' {
        publishDir = [
            path: { "${params.outdir}/epigenome/tobias/footprints/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }
    withName: '.*:FASTQ_EPIGENOME_BOWTIE2:TOBIAS_BINDETECT' {
        // Notebook: BINDetect with HOCOMOCO v11 motifs
        publishDir = [
            path: { "${params.outdir}/epigenome/tobias/bindetect/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // =========================================================================
    //  VARIANTS branch (GATK preprocessing + multi-caller)
    // =========================================================================
    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:BWA_MEM' {
        ext.args   = { "-M -R '@RG\\tID:${meta.id}\\tSM:${meta.id}\\tPL:ILLUMINA\\tLB:${meta.id}'" }
        ext.prefix = { "${meta.id}.bwa" }
        publishDir = [ enabled: false ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:GATK4_MARKDUPLICATES' {
        ext.prefix = { "${meta.id}.md.bam" }
        publishDir = [
            path: { "${params.outdir}/variants/markduplicates/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.metrics"
        ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:GATK4_BASERECALIBRATOR' {
        ext.prefix = { "${meta.id}.recal" }
        publishDir = [ enabled: false ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:GATK4_APPLYBQSR' {
        ext.prefix = { "${meta.id}.recalibrated" }
        ext.suffix = 'bam'
        publishDir = [
            path: { "${params.outdir}/variants/bam/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bam,bai}"
        ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:INDEX_ANALYSIS' {
        publishDir = [
            path: { "${params.outdir}/variants/bam/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bai,csi}"
        ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:GATK4_HAPLOTYPECALLER' {
        ext.prefix = { "${meta.id}.haplotypecaller" }
        publishDir = [
            path: { "${params.outdir}/variants/vcf/haplotypecaller/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.vcf.gz*"
        ]
    }
    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:DEEPVARIANT_RUNDEEPVARIANT' {
        ext.args   = { "--model_type=${params.deepvariant_model_type}" }
        ext.prefix = { "${meta.id}.deepvariant" }
        publishDir = [
            path: { "${params.outdir}/variants/vcf/deepvariant/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.vcf.gz*"
        ]
    }
    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:VCF_FILTER_REGIONS' {
        publishDir = [
            path: { "${params.outdir}/variants/vcf_in_peaks/${meta.caller}/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.vcf.gz*"
        ]
    }
    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:VCF_STATS' {
        publishDir = [
            path: { "${params.outdir}/variants/stats/${meta.caller}/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bcftools_stats.txt,variant_counts_mqc.tsv}"
        ]
    }
    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:FREEBAYES' {
        ext.prefix = { "${meta.id}.freebayes" }
        publishDir = [
            path: { "${params.outdir}/variants/vcf/freebayes/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.vcf.gz*"
        ]
    }
    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:BCFTOOLS_MPILEUP' {
        // Notebook: bcftools mpileup | bcftools call -mv
        ext.args2  = '--multiallelic-caller --variants-only'
        ext.prefix = { "${meta.id}.bcftools" }
        publishDir = [
            path: { "${params.outdir}/variants/vcf/bcftools/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.vcf.gz*"
        ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:ENSEMBLVEP_VEP' {
        // Notebook: VEP annotation (VCF output)
        ext.args   = '--everything --vcf --force_overwrite'
        ext.prefix = { "${meta.id}.${meta.caller}.vep" }
        publishDir = [
            path: { "${params.outdir}/variants/vep/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{vcf.gz,html}"
        ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:VCF2MAF' {
        ext.prefix = { "${meta.id}.${meta.caller}" }
        publishDir = [
            path: { "${params.outdir}/variants/maf/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.maf"
        ]
    }

    withName: '.*:FASTQ_VARIANT_CALLING_ATAC:MAFTOOLS_ONCOPLOT' {
        publishDir = [
            path: { "${params.outdir}/variants/oncoplot" },
            mode: params.publish_dir_mode
        ]
    }

    // =========================================================================
    //  CNV branch (QDNAseq)
    // =========================================================================
    withName: '.*:FILTER_BAM_OUTSIDE_PEAKS' {
        ext.args   = '-v'
        ext.suffix = 'bam'
        ext.prefix = { "${meta.id}.outside_peaks" }
        publishDir = [
            path: { "${params.outdir}/cnv/outside_peaks_bam/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.bam"
        ]
    }
    withName: '.*:INDEX_CNV_BAM' {
        publishDir = [
            path: { "${params.outdir}/cnv/outside_peaks_bam/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bai,csi}"
        ]
    }
    withName: '.*:BAM_CNV_QDNASEQ:QDNASEQ' {
        // Notebook: 100kb bins, sqrt segmentation, loss=-0.4 / gain=+0.4
        ext.singularity_pull_docker_container = true
        publishDir = [
            path: { "${params.outdir}/cnv/qdnaseq/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // =========================================================================
    //  TELOMERE branch (TelomereHunter)
    // =========================================================================
    withName: '.*:BAM_TELOMERE_TELOMEREHUNTER:TELOMEREHUNTER' {
        // Notebook: telomerehunter -ibt <bam> -b <cytoBand>
        publishDir = [
            path: { "${params.outdir}/telomere/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // =========================================================================
    //  MITO branch (mgatk)
    // =========================================================================
    withName: '.*:BAM_MITO_MGATK:MGATK' {
        // Notebook: mgatk call --g hg38 --keep-duplicates
        ext.singularity_pull_docker_container = true
        publishDir = [
            path: { "${params.outdir}/mito/mgatk/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // =========================================================================
    //  REGULATORY NETWORK branch (ANANSE / Coltron)
    // =========================================================================
    withName: 'ANANSE_BINDING' {
        publishDir = [
            path: { "${params.outdir}/regulatory_networks/ananse/binding/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'ANANSE_NETWORK' {
        publishDir = [
            path: { "${params.outdir}/regulatory_networks/ananse/network/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.network.tsv"
        ]
    }

    withName: 'ANANSE_INFLUENCE' {
        publishDir = [
            path: { "${params.outdir}/regulatory_networks/ananse/influence" },
            mode: params.publish_dir_mode,
            pattern: "*.tsv"
        ]
    }

    withName: 'COLTRON' {
        publishDir = [
            path: { "${params.outdir}/regulatory_networks/coltron/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // =========================================================================
    //  Reference preparation
    // =========================================================================
    withName: 'BOWTIE2_BUILD|BWA_INDEX|SAMTOOLS_FAIDX|GATK4_CREATESEQUENCEDICTIONARY|GUNZIP' {
        publishDir = [
            path: { "${params.outdir}/reference" },
            mode: params.publish_dir_mode,
            enabled: false
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
